      "required": true,
      "options": [
        "Pass",
        "Fail"
      ]
    },
    "sendToRework": {
      "label": "Send to rework",
      "type": "select",
      "required": false,
      "options": [
        "No",
        "Yes"
      ],
      "defaultValue": "No"
    },
    "reworkReason": {
      "label": "Rework reason",
      "type": "textarea",
      "required": false
    },
    "reworkEntry": {
      "label": "Rework entry",
      "type": "textarea",
      "required": false
    },
    "jigused": {
      "label": "Jig used",
      "type": "text",
      "required": true
    },
    "jig-id": {
      "label": "Enter JIG ID",
      "type": "text",
      "required": true
    },
    "part-status": {
      "label": "Part status",
      "type": "select",
      "required": true,
      "options": [
        "Active",
        "In Rework",
        "Scrap"
      ],
      "defaultValue": "Active"
    }
