  "fields": {
    "startSerial": { "label": "First stamped serial", "type": "text", "required": true },
    "endSerial": { "label": "Last stamped serial", "type": "text", "required": true },
    "batchNumber": { "label": "Batch number", "type": "text", "required": true },
    "fromSerial": { "label": "From serial", "type": "text", "required": false },
    "toSerial": { "label": "To serial", "type": "text", "required": false },
    "jigUsed": {
      "label": "Jig used",
      "type": "select",
      "required": true,
      "options": ["JIG 01", "JIG 02"]
    },
    "robotUsed": { "label": "Robot used", "type": "text", "required": false },
    "paintStatus": {
      "label": "Paint status",
      "type": "select",
      "required": false,
      "options": ["Pass", "Rework", "Hold"]
    },
    "partStatus": {
      "label": "Part status",
      "type": "select",
      "required": true,
      "options": ["OK", "Not OK"]
    },
    "scrapStatus": {
      "label": "Scrap decision",
      "type": "select",
      "required": false,
      "options": ["Continue", "Scrap"]
    },
    "reworkStatus": {
      "label": "Final rework",
      "type": "select",
      "required": true,
      "options": ["No Rework", "Rework Required", "Reworked OK", "Scrap"]
    },
    "notes": { "label": "Notes", "type": "textarea", "required": false }
  }
